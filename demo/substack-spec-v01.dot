digraph substack_spec_v01 {
    graph [
        goal="Build the Substack Creator Newsletter Engine v01 from demo/substack-spec-v01.md and demo/substack-dod-v01.md, including UI flow constraints in demo/substack-spec-v01-ui.dot.",
        rankdir=LR,
        default_max_retry=3,
        retry_target="debate_consolidate",
        fallback_retry_target="plan_fanout",
        loop_restart_signature_limit=5,
        loop_restart_persist_keys="last_failing_acs",
        provenance_version="1",
        model_stylesheet="
            * { llm_model: gemini-3-flash-preview; llm_provider: google; }
            .hard { llm_model: gemini-2.5-pro; llm_provider: google; }
            .verify { llm_model: gemini-2.5-flash; llm_provider: google; }
            .review { llm_model: claude-sonnet-4.5; llm_provider: anthropic; }
            .branch-a { llm_model: gemini-3-pro-preview; llm_provider: google; }
            .branch-b { llm_model: claude-sonnet-4.5; llm_provider: anthropic; }
            .branch-c { llm_model: gpt-5.2-codex; llm_provider: openai; }
        "
    ]

    start [shape=Mdiamond, label="Start"]
    exit  [shape=Msquare, label="Exit"]

    subgraph cluster_bootstrap {
        label="Bootstrap"

        check_toolchain [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh -c 'set -e; command -v node >/dev/null; command -v npm >/dev/null; command -v git >/dev/null; echo toolchain_ok'"
        ]

        expand_spec [
            shape=box,
            auto_status=true,
            prompt="Goal: $goal

Read these authoritative project sources:
- demo/substack-spec-v01.md
- demo/substack-dod-v01.md
- demo/substack-spec-v01-ui.dot

Create .ai/spec.md with these sections:
1) Source Contract: copy the key constraints from the three source files without weakening meaning, and include the exact file paths.
2) Product Scope and Non-Goals: pure React frontend, no backend, no live deployment during acceptance.
3) Runtime Behavior Contract: setup flow, dashboard, trending topics, new post pipeline, demo replay behavior, reset behavior.
4) Data and LLM Contract: IndexedDB persistence, structured JSON outputs, retry/backoff, production-vs-test model intent.
5) Test and Evidence Contract: IT-1 through IT-12 plus manifest requirements under .ai/test-evidence/latest/.
6) File/Module Targets: concrete implementation modules to guide planning and fan-out implementation.

Include this verbatim user request block in .ai/spec.md:
BEGIN_USER_REQUEST
Use the create-dotfile skill to create a dotfile from the substack spec and DoD, including the UI spec dotfile.
END_USER_REQUEST

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Unable to produce .ai/spec.md from provided Substack sources\",\"failure_signature\":\"expand_spec_io\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        check_dod [
            shape=box,
            label="DoD exists?",
            prompt="Read .ai/definition_of_done.md if present and demo/substack-dod-v01.md.

If demo/substack-dod-v01.md exists and is non-empty:
- Ensure .ai/definition_of_done.md exists and is adequate.
- If .ai/definition_of_done.md is missing or weaker, copy demo/substack-dod-v01.md into .ai/definition_of_done.md.
- Write status JSON: {\"status\":\"has_dod\"}

If demo/substack-dod-v01.md is missing/unreadable, write status JSON:
{\"status\":\"needs_dod\"}

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH). For operational failure write:
{\"status\":\"fail\",\"failure_reason\":\"Could not read or prepare DoD artifacts\",\"failure_signature\":\"dod_check_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]
    }

    subgraph cluster_dod {
        label="DoD Fanout"

        dod_fanout [shape=component, label="DoD Fan-Out"]

        dod_a [
            shape=box,
            class="branch-a",
            auto_status=true,
            prompt="Read .ai/spec.md and draft a DoD at .ai/dod_a.md only if a canonical DoD is missing.

The draft must include:
- Scope, non-goals, and deliverables
- Acceptance criteria mapped to IT scenarios
- Explicit evidence requirements under .ai/test-evidence/latest/
- Browser evidence expectations (screenshots + console/trace artifacts)

If demo/substack-dod-v01.md already exists and is adequate, write .ai/dod_a.md as a short justification for reusing it unchanged.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"DoD branch A failed\",\"failure_signature\":\"dod_branch_a_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        dod_b [
            shape=box,
            class="branch-b",
            auto_status=true,
            prompt="Read .ai/spec.md and draft a DoD at .ai/dod_b.md only if a canonical DoD is missing.

The draft must include:
- Scope, non-goals, and deliverables
- Acceptance criteria mapped to IT scenarios
- Explicit evidence requirements under .ai/test-evidence/latest/
- Browser evidence expectations (screenshots + console/trace artifacts)

If demo/substack-dod-v01.md already exists and is adequate, write .ai/dod_b.md as a short justification for reusing it unchanged.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"DoD branch B failed\",\"failure_signature\":\"dod_branch_b_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        dod_c [
            shape=box,
            class="branch-c",
            auto_status=true,
            prompt="Read .ai/spec.md and draft a DoD at .ai/dod_c.md only if a canonical DoD is missing.

The draft must include:
- Scope, non-goals, and deliverables
- Acceptance criteria mapped to IT scenarios
- Explicit evidence requirements under .ai/test-evidence/latest/
- Browser evidence expectations (screenshots + console/trace artifacts)

If demo/substack-dod-v01.md already exists and is adequate, write .ai/dod_c.md as a short justification for reusing it unchanged.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"DoD branch C failed\",\"failure_signature\":\"dod_branch_c_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        consolidate_dod [
            shape=box,
            auto_status=true,
            prompt="Read .ai/dod_a.md, .ai/dod_b.md, .ai/dod_c.md when present, plus demo/substack-dod-v01.md.

Produce .ai/definition_of_done.md:
- If demo/substack-dod-v01.md exists, preserve it as canonical unless a branch found objective gaps.
- If gaps exist, add only minimal corrective sections and keep original constraints intact.
- Ensure acceptance criteria and test evidence expectations include IT-1 through IT-12 and screenshot/trace requirements.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Unable to consolidate DoD artifacts\",\"failure_signature\":\"missing_dod_files\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]
    }

    subgraph cluster_planning {
        label="Planning Fanout"

        plan_fanout [shape=component, label="Plan Fan-Out"]

        plan_a [
            shape=box,
            class="branch-a",
            auto_status=true,
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, and .ai/postmortem_latest.md if present.

Write .ai/plan_a.md with a concrete implementation plan for:
- Foundation/state/routing and IndexedDB
- Content workflow (trending + topic/research/outline/write cycles/complete)
- Demo replay/session recording/reset
- Test harness and evidence scripts

Include explicit file targets and script ownership for:
- scripts/validate-fmt.sh
- scripts/validate-build.sh
- scripts/validate-test.sh
- scripts/validate-browser.sh
- scripts/validate-artifacts.sh

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Plan branch A failed\",\"failure_signature\":\"plan_branch_a_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        plan_b [
            shape=box,
            class="branch-b",
            auto_status=true,
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, and .ai/postmortem_latest.md if present.

Write .ai/plan_b.md with a concrete implementation plan for:
- Foundation/state/routing and IndexedDB
- Content workflow (trending + topic/research/outline/write cycles/complete)
- Demo replay/session recording/reset
- Test harness and evidence scripts

Include explicit file targets and script ownership for:
- scripts/validate-fmt.sh
- scripts/validate-build.sh
- scripts/validate-test.sh
- scripts/validate-browser.sh
- scripts/validate-artifacts.sh

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Plan branch B failed\",\"failure_signature\":\"plan_branch_b_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        plan_c [
            shape=box,
            class="branch-c",
            auto_status=true,
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, and .ai/postmortem_latest.md if present.

Write .ai/plan_c.md with a concrete implementation plan for:
- Foundation/state/routing and IndexedDB
- Content workflow (trending + topic/research/outline/write cycles/complete)
- Demo replay/session recording/reset
- Test harness and evidence scripts

Include explicit file targets and script ownership for:
- scripts/validate-fmt.sh
- scripts/validate-build.sh
- scripts/validate-test.sh
- scripts/validate-browser.sh
- scripts/validate-artifacts.sh

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Plan branch C failed\",\"failure_signature\":\"plan_branch_c_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        debate_consolidate [
            shape=box,
            auto_status=true,
            prompt="Read .ai/plan_a.md, .ai/plan_b.md, .ai/plan_c.md, .ai/spec.md, and .ai/definition_of_done.md.
If .ai/postmortem_latest.md exists, ensure every unresolved issue is addressed.

Write a single execution plan to .ai/plan_final.md that includes:
- Module fan-out boundaries and merge expectations
- Script contracts for validate-fmt/build/test/browser/artifacts
- Mapping IT-1..IT-12 to deterministic evidence artifacts
- Recovery expectations for repair passes

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Unable to consolidate planning branches\",\"failure_signature\":\"plan_consolidation_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]
    }

    subgraph cluster_implement_verify {
        label="Implement and Verify"

        implement_fanout [shape=component, label="Implementation Fan-Out"]

        implement_foundation [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=320,
            max_tokens=32768,
            prompt="Goal: $goal

Read .ai/plan_final.md, .ai/spec.md, .ai/definition_of_done.md, and demo/substack-spec-v01-ui.dot.

Implement foundation deliverables:
- React app shell and route gates (first run -> Settings, otherwise Dashboard).
- IndexedDB persistence layer using idb for settings, drafts, sessions, and post history.
- Settings hub with parallel setup options, rich input control, confirm/back loops, and reset-everything action.
- Shared client-side LLM utility with schema-enforced structured output, retry/backoff, and model-intent routing:
  production intent: Gemini 3.1 Flash + Gemini 3.1 Pro, test intent: Gemini 2.5 Flash Lite.
- Ensure no backend service is introduced.

Write progress to .ai/module_foundation_impl.md.

Repair-pass rule: if .ai/postmortem_latest.md or .ai/review_consensus.md exists, read it first, target only listed gaps, run sh scripts/validate-build.sh, and re-read each touched file before exit.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Foundation module implementation failed\",\"failure_signature\":\"implement_foundation_failure\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        implement_content_flow [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=320,
            max_tokens=32768,
            prompt="Goal: $goal

Read .ai/plan_final.md, .ai/spec.md, .ai/definition_of_done.md, and demo/substack-spec-v01-ui.dot.

Implement content workflow deliverables:
- Dashboard: New Post, Trending Topics, settings entry, post/draft listing and resume/view actions.
- Trending Topics: parallel grounded research calls, deterministic trend visualization, 3 synthesized prompts, prefill jump to Topic.
- New Post pipeline: Topic -> Research -> Outline -> Write/Edit/Guardrails (automatic 3-cycle) -> Complete.
- Research metadata and citation lineage persistence (URL, title, author, publication date) through final Markdown footnotes.
- Visual behavior contract: step dots, card primitive reuse, horizontal progress bars only, Substack-like final post preview.

Write progress to .ai/module_content_flow_impl.md.

Repair-pass rule: if .ai/postmortem_latest.md or .ai/review_consensus.md exists, read it first, target only listed gaps, run sh scripts/validate-build.sh, and re-read each touched file before exit.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Content workflow implementation failed\",\"failure_signature\":\"implement_content_flow_failure\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        implement_demo_mode [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=320,
            max_tokens=32768,
            prompt="Goal: $goal

Read .ai/plan_final.md, .ai/spec.md, .ai/definition_of_done.md, and demo/substack-spec-v01-ui.dot.

Implement demo and session lifecycle deliverables:
- Production-mode session recording of inputs, model outputs, and intermediate state.
- Demo session picker over recorded sessions.
- Demo replay through production code path with subtle text fade-in, delayed attachment rendering, and highlighted next-button behavior.
- Cache-miss behavior: explicit error and no live API fallback.
- Ship one bundled P&G session including cached first-run configuration.
- Ensure reset-everything wipes all IndexedDB stores and returns to first-run state.

Write progress to .ai/module_demo_mode_impl.md.

Repair-pass rule: if .ai/postmortem_latest.md or .ai/review_consensus.md exists, read it first, target only listed gaps, run sh scripts/validate-build.sh, and re-read each touched file before exit.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Demo/session module implementation failed\",\"failure_signature\":\"implement_demo_mode_failure\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        implement_validation [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=320,
            max_tokens=32768,
            prompt="Goal: $goal

Read .ai/plan_final.md, .ai/spec.md, and .ai/definition_of_done.md.

Implement test and validation deliverables:
- Create/repair scripts:
  scripts/validate-fmt.sh
  scripts/validate-build.sh
  scripts/validate-test.sh
  scripts/validate-browser.sh
  scripts/validate-artifacts.sh
- Each script must start with:
  #!/bin/sh
  set -e
  trap 'echo \"KILROY_VALIDATE_FAILURE: <script-name> crashed at line $LINENO - postmortem must repair <script-name>\"' EXIT
  ...
  trap - EXIT
- validate-test.sh must run integration tests before smoke tests, support manual real-model option, and write deterministic evidence under .ai/test-evidence/latest/.
- validate-test.sh must always write .ai/test-evidence/latest/manifest.json with IT-1..IT-12 status + artifact metadata even when failing.
- UI scenarios (IT-2..IT-8, IT-11, IT-12) must include screenshot evidence; browser scenarios must include console/unhandled summaries and trace/log artifacts or explicit none markers.
- validate-artifacts.sh must verify manifest coverage, required artifact types, and DoD scenario-ID parity.

Write progress to .ai/module_validation_impl.md.

Repair-pass rule: if .ai/postmortem_latest.md or .ai/review_consensus.md exists, read it first, target only listed gaps, run sh scripts/validate-build.sh, and re-read each touched file before exit.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Validation and evidence harness implementation failed\",\"failure_signature\":\"implement_validation_failure\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        merge_implementation [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=220,
            max_tokens=32768,
            prompt="Read .ai/module_foundation_impl.md, .ai/module_content_flow_impl.md, .ai/module_demo_mode_impl.md, .ai/module_validation_impl.md, plus .ai/spec.md and .ai/definition_of_done.md.

Synthesize modules into one coherent implementation:
- Resolve cross-module conflicts without discarding passing behavior.
- Ensure scripts/validate-fmt.sh, scripts/validate-build.sh, scripts/validate-test.sh, scripts/validate-browser.sh, and scripts/validate-artifacts.sh exist and are executable.
- Ensure each validate script starts with #!/bin/sh, set -e, and a KILROY_VALIDATE_FAILURE trap.
- Ensure evidence contract paths are consistent with .ai/test-evidence/latest/manifest.json.

Write .ai/merge_implementation.md summarizing merged decisions and touched files.

Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure:
{\"status\":\"fail\",\"failure_reason\":\"Module merge failed due to missing deliverables or unresolved conflicts\",\"failure_signature\":\"missing_module_outputs\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        check_implement [shape=diamond, label="Implement OK?"]

        fix_fmt [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh scripts/validate-fmt.sh --fix || { echo 'KILROY_VALIDATE_FAILURE: validate-fmt.sh missing or failed - postmortem must write scripts/validate-fmt.sh'; exit 1; }"
        ]

        verify_fmt [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh scripts/validate-fmt.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-fmt.sh missing or failed - postmortem must write scripts/validate-fmt.sh'; exit 1; }"
        ]
        check_fmt [shape=diamond, label="Fmt OK?"]

        verify_build [
            shape=parallelogram,
            tool_command="sh scripts/validate-build.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-build.sh missing or failed - postmortem must write scripts/validate-build.sh'; exit 1; }"
        ]
        check_build [shape=diamond, label="Build OK?"]

        verify_test [
            shape=parallelogram,
            tool_command="sh scripts/validate-test.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-test.sh missing or failed - postmortem must write scripts/validate-test.sh'; exit 1; }"
        ]
        check_test [shape=diamond, label="Tests OK?"]

        verify_browser [
            shape=parallelogram,
            collect_browser_artifacts=true,
            tool_command="sh scripts/validate-browser.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-browser.sh missing or failed - postmortem must write scripts/validate-browser.sh'; exit 1; }"
        ]
        check_browser [shape=diamond, label="Browser OK?"]

        verify_artifacts [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh scripts/validate-artifacts.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-artifacts.sh missing or failed - postmortem must write scripts/validate-artifacts.sh'; exit 1; }"
        ]
        check_artifacts [shape=diamond, label="Artifacts OK?"]

        verify_fidelity [
            shape=box,
            class="verify",
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, .ai/verify_fidelity.md (if present), .ai/test-evidence/latest/manifest.json, and relevant implementation files.

Evaluate these grouped acceptance checks and map each to concrete file paths:
AC1: src/**/settings* and src/**/router* and src/**/indexeddb* - first-run routing, setup flow, persistence.
AC2: src/**/dashboard* and src/**/history* and src/**/draft* - dashboard actions and resume/view flows.
AC3: src/**/trending* and src/**/research* - grounded research, deterministic trends, prompt handoff.
AC4: src/**/new-post* and src/**/outline* and src/**/write* and src/**/complete* - full Topic->Complete pipeline with automatic write cycles.
AC5: src/**/citation* and src/**/markdown* - citation lineage, footnote rendering, attribution persistence.
AC6: src/**/demo* and src/demo/** - session picker/replay, bundled P&G demo, cache-miss no-fallback behavior.
AC7: src/**/llm* and src/**/schema* - structured outputs, retry/backoff, production/test model intent.
AC8: scripts/validate-build.sh and railway.json/Procfile/README* - build/deploy-readiness by static review only, no live deployment execution.
AC9: scripts/validate-test.sh and scripts/validate-browser.sh and test sources - integration before smoke, manual mode option, browser evidence capture.
AC10: .ai/test-evidence/latest/manifest.json and .ai/test-evidence/latest/** - IT-1..IT-12 manifest coverage and required artifact types.
AC11: src/**/style* and src/**/card* and src/**/progress* - Substack-like visual contract including bars, cards, and serif post preview.

Write .ai/verify_fidelity.md with pass/fail verdict and evidence per AC1..AC11.
If all checks pass, write:
{\"status\":\"success\"}

If any check fails, write:
{\"status\":\"fail\",\"failure_reason\":\"List failed AC IDs and concise evidence\",\"failure_signature\":\"ACx,ACy (sorted IDs only)\",\"failure_class\":\"deterministic_agent_bug\"}
Use sorted comma-separated AC IDs for failure_signature (example: AC2,AC10).

Write status to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH)."
        ]
        check_impl [shape=diamond, label="Impl OK?"]
    }

    subgraph cluster_review {
        label="Review Fanout"

        review_fanout [shape=component, label="Review Fan-Out"]

        review_a [
            shape=box,
            class="branch-a",
            auto_status=true,
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, .ai/verify_fidelity.md, .ai/test-evidence/latest/manifest.json, and implementation files.

Write .ai/review_a.md with:
- APPROVED or REJECTED verdict
- Explicit AC IDs and IT scenario IDs supporting the verdict
- High/medium/low findings with concrete file evidence

Do not write status fail for a rejection verdict; keep verdict in the review file.
Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on operational failure:
{\"status\":\"fail\",\"failure_reason\":\"Review branch A could not complete analysis\",\"failure_signature\":\"review_branch_a_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        review_b [
            shape=box,
            class="branch-b",
            auto_status=true,
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, .ai/verify_fidelity.md, .ai/test-evidence/latest/manifest.json, and implementation files.

Write .ai/review_b.md with:
- APPROVED or REJECTED verdict
- Explicit AC IDs and IT scenario IDs supporting the verdict
- High/medium/low findings with concrete file evidence

Do not write status fail for a rejection verdict; keep verdict in the review file.
Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on operational failure:
{\"status\":\"fail\",\"failure_reason\":\"Review branch B could not complete analysis\",\"failure_signature\":\"review_branch_b_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        review_c [
            shape=box,
            class="branch-c",
            auto_status=true,
            prompt="Read .ai/spec.md, .ai/definition_of_done.md, .ai/verify_fidelity.md, .ai/test-evidence/latest/manifest.json, and implementation files.

Write .ai/review_c.md with:
- APPROVED or REJECTED verdict
- Explicit AC IDs and IT scenario IDs supporting the verdict
- High/medium/low findings with concrete file evidence

Do not write status fail for a rejection verdict; keep verdict in the review file.
Write to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on operational failure:
{\"status\":\"fail\",\"failure_reason\":\"Review branch C could not complete analysis\",\"failure_signature\":\"review_branch_c_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]

        review_consensus [
            shape=box,
            class="review",
            auto_status=true,
            goal_gate=true,
            retry_target="postmortem",
            prompt="Read .ai/review_a.md, .ai/review_b.md, .ai/review_c.md, .ai/verify_fidelity.md, and .ai/definition_of_done.md.

Write .ai/review_consensus.md with:
- Consensus verdict
- Failed AC IDs (if any)
- Concrete fix directives grouped by module/file

Routing status rules:
- If at least two reviews are APPROVED and no unresolved high-severity AC gaps remain, write:
  {\"status\":\"success\"}
- Otherwise write:
  {\"status\":\"rejected\"}

Do NOT use {\"status\":\"fail\"} for a rejection verdict.
Use fail only for operational inability to read required artifacts:
{\"status\":\"fail\",\"failure_reason\":\"Consensus review could not read required review artifacts\",\"failure_signature\":\"review_consensus_io\",\"failure_class\":\"deterministic_agent_bug\"}

Write status to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH)."
        ]
    }

    subgraph cluster_postmortem {
        label="Postmortem"

        postmortem [
            shape=box,
            auto_status=true,
            prompt="Read these artifacts when present:
- .ai/review_consensus.md
- .ai/verify_fidelity.md
- .ai/implementation_log.md
- .ai/module_foundation_impl.md
- .ai/module_content_flow_impl.md
- .ai/module_demo_mode_impl.md
- .ai/module_validation_impl.md
- .ai/test-evidence/latest/manifest.json
- Evidence files referenced by manifest entries for failed/suspicious IT scenarios

Write .ai/postmortem_latest.md with:
- Root causes (not symptoms)
- Passing areas to preserve
- Targeted repair actions by file
- Evidence file paths actually read (or explicit reason each was skipped)

Progress detection contract:
- Extract current failing AC set from .ai/verify_fidelity.md and .ai/review_consensus.md.
- Read prior context key last_failing_acs.
- If current set is identical to last_failing_acs, route needs_replan.
- If this is first failure or AC set changed/smaller, route impl_repair.
- If primary failure is missing tools/scripts/runtime prerequisites, route needs_toolchain.
- Include context_updates in status:
  {\"context_updates\":{\"last_failing_acs\":\"AC1,AC7\"}}

Write one of these statuses to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):
- {\"status\":\"impl_repair\",\"context_updates\":{\"last_failing_acs\":\"...\"}}
- {\"status\":\"needs_replan\",\"context_updates\":{\"last_failing_acs\":\"...\"}}
- {\"status\":\"needs_toolchain\",\"context_updates\":{\"last_failing_acs\":\"...\"}}

If postmortem itself cannot complete, write:
{\"status\":\"fail\",\"failure_reason\":\"Postmortem could not classify failure for recovery routing\",\"failure_signature\":\"postmortem_internal_error\",\"failure_class\":\"deterministic_agent_bug\"}"
        ]
    }

    start -> check_toolchain
    check_toolchain -> expand_spec [condition="outcome=success"]
    check_toolchain -> check_toolchain [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_toolchain -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_toolchain -> postmortem
    expand_spec -> check_dod

    check_dod -> plan_fanout [condition="outcome=has_dod"]
    check_dod -> dod_fanout [condition="outcome=needs_dod"]
    check_dod -> check_dod [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_dod -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_dod -> dod_fanout

    dod_fanout -> dod_a
    dod_fanout -> dod_b
    dod_fanout -> dod_c
    dod_a -> consolidate_dod
    dod_b -> consolidate_dod
    dod_c -> consolidate_dod
    consolidate_dod -> plan_fanout

    plan_fanout -> plan_a
    plan_fanout -> plan_b
    plan_fanout -> plan_c
    plan_a -> debate_consolidate
    plan_b -> debate_consolidate
    plan_c -> debate_consolidate

    debate_consolidate -> implement_fanout
    implement_fanout -> implement_foundation
    implement_fanout -> implement_content_flow
    implement_fanout -> implement_demo_mode
    implement_fanout -> implement_validation
    implement_foundation -> merge_implementation
    implement_content_flow -> merge_implementation
    implement_demo_mode -> merge_implementation
    implement_validation -> merge_implementation

    merge_implementation -> check_implement
    check_implement -> fix_fmt [condition="outcome=success"]
    check_implement -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_implement -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_implement -> postmortem

    fix_fmt -> verify_fmt
    verify_fmt -> check_fmt
    check_fmt -> verify_build [condition="outcome=success"]
    check_fmt -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_fmt -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_fmt -> postmortem

    verify_build -> check_build
    check_build -> verify_test [condition="outcome=success"]
    check_build -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_build -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_build -> postmortem

    verify_test -> check_test
    check_test -> verify_browser [condition="outcome=success"]
    check_test -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_test -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_test -> postmortem

    verify_browser -> check_browser
    check_browser -> verify_artifacts [condition="outcome=success"]
    check_browser -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_browser -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_browser -> postmortem

    verify_artifacts -> check_artifacts
    check_artifacts -> verify_fidelity [condition="outcome=success"]
    check_artifacts -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_artifacts -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_artifacts -> postmortem

    verify_fidelity -> check_impl
    check_impl -> review_fanout [condition="outcome=success"]
    check_impl -> implement_fanout [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_impl -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_impl -> postmortem

    review_fanout -> review_a
    review_fanout -> review_b
    review_fanout -> review_c
    review_a -> review_consensus
    review_b -> review_consensus
    review_c -> review_consensus

    review_consensus -> exit [condition="outcome=success"]
    review_consensus -> postmortem [condition="outcome=rejected"]
    review_consensus -> postmortem

    postmortem -> check_toolchain [condition="outcome=fail && context.failure_class=transient_infra"]
    postmortem -> implement_fanout [condition="outcome=impl_repair"]
    postmortem -> plan_fanout [condition="outcome=needs_replan"]
    postmortem -> check_toolchain [condition="outcome=needs_toolchain"]
    postmortem -> implement_fanout
}
