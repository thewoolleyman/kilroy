digraph substack_pipeline {
    graph [
        goal="Build the Substack Creator Newsletter Engine — a pure React frontend (no backend) for brand-driven Substack content creation. Client-side Gemini LLM integration (3.1 Flash for fast tasks, 3.1 Pro with extended thinking for important tasks, 2.5 Flash Lite for tests). IndexedDB persistence via idb library. Setup flow with API key, company identity, voice definition, and guardrails — each confirmed by Pro. Dashboard with post history, draft management, New Post and Trending Topics access. Trending Topics uses Flash with search grounding for research, Pro synthesizes 3 writing prompts. New Post pipeline: Topic (rich input) then Research (Flash search grounding, source metadata) then Outline (Pro one-shot) then Write/Edit/Guardrails (3 automatic Pro cycles) then Complete (serif footnoted citations with attribution lineage). Demo mode replays recorded sessions through production code path with fade-in prefills; ships with one bundled P&G session; cache miss shows error, no API fallback. Visual design matches Substack (serif fonts, horizontal dot step indicators, card primitives, accent progress bars, numbered footnotes). Test infrastructure: integration tests with canned data, smoke tests with live Flash Lite, manual test option with real models. Deployment readiness for GitHub to Railway validated by code review only — no live deployment execution.",
        rankdir=LR,
        default_max_retry=3,
        retry_target="plan_work",
        fallback_retry_target="debate_consolidate",
        provenance_version="1",
        loop_restart_persist_keys="last_failing_acs",
        loop_restart_signature_limit=5,
        model_stylesheet="
            * { llm_model: claude-sonnet-4.6; llm_provider: anthropic; }
            .hard { llm_model: claude-opus-4.6; llm_provider: anthropic; }
            .verify { llm_model: gemini-3-pro-preview; llm_provider: google; }
            .branch-a { llm_model: claude-opus-4.6; llm_provider: anthropic; }
            .branch-b { llm_model: gemini-3-pro-preview; llm_provider: google; }
            .branch-c { llm_model: gpt-5.3-codex; llm_provider: openai; }
        "
    ]

    exit [shape=Msquare, label="Exit"]

    // =========================================================================
    // Bootstrap
    // =========================================================================

    subgraph cluster_bootstrap {
        label="Bootstrap"
        start [shape=Mdiamond, label="Start"]

        check_toolchain [
            shape=parallelogram,
            max_retries=0,
            tool_command="command -v node >/dev/null 2>&1 && command -v npm >/dev/null 2>&1 && node --version && npm --version"
        ]

        expand_spec [
            shape=box,
            auto_status=true,
            prompt="Goal: $goal\n\nThe project specification is at demo/substack-spec-v01.md and the Definition of Done is at demo/substack-dod-v01.md. The UI flow diagram is at demo/substack-spec-v01-ui.dot.\n\nRead all three files. If .ai/spec.md does not exist or is a placeholder, copy the spec verbatim to .ai/spec.md, appending a reference to the UI flow diagram. If .ai/definition_of_done.md does not exist or is a placeholder, copy the DoD verbatim to .ai/definition_of_done.md. If both already exist and are adequate, skip.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=expand_spec_fail."
        ]

        check_dod [
            shape=box,
            label="DoD exists?",
            prompt="Check if .ai/definition_of_done.md exists and contains substantive content (not placeholder text).\n\nApply DoD rubric: does it have scope (in/out), deliverables, acceptance criteria, verification approach, quality/safety gates, and non-goals? Apply coverage checklist: build, tests, lint, docs, compatibility, security, ops, perf.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):\n- If the file exists and is adequate: status=has_dod\n- If the file is missing or inadequate: status=needs_dod\n- On error: status=fail with failure_reason and failure_class"
        ]
    }

    // =========================================================================
    // DoD Fanout
    // =========================================================================

    subgraph cluster_dod {
        label="DoD Fanout"
        node [shape=box]

        dod_fanout [shape=component, label="DoD Fan-Out"]

        dod_a [
            class="branch-a",
            prompt="Read .ai/spec.md. Propose a Definition of Done for the Substack Creator Newsletter Engine.\n\nThe DoD must be outcomes and evidence, not a plan. Every item must be verifiable (pass/fail). Do not prescribe implementation approach. Include: scope (in/out), deliverables with locations, acceptance criteria covering all features (setup, dashboard, trending, new post, demo, LLM integration, persistence, visual design, testing), verification approach, quality/safety gates, non-goals.\n\nApply coverage checklist: build, tests, lint, docs, compatibility, security, ops, performance.\n\nWrite the proposed DoD to .ai/dod_a.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        dod_b [
            class="branch-b",
            prompt="Read .ai/spec.md. Propose a Definition of Done for the Substack Creator Newsletter Engine.\n\nThe DoD must be outcomes and evidence, not a plan. Every item must be verifiable (pass/fail). Do not prescribe implementation approach. Include: scope (in/out), deliverables with locations, acceptance criteria covering all features (setup, dashboard, trending, new post, demo, LLM integration, persistence, visual design, testing), verification approach, quality/safety gates, non-goals.\n\nApply coverage checklist: build, tests, lint, docs, compatibility, security, ops, performance.\n\nWrite the proposed DoD to .ai/dod_b.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        dod_c [
            class="branch-c",
            prompt="Read .ai/spec.md. Propose a Definition of Done for the Substack Creator Newsletter Engine.\n\nThe DoD must be outcomes and evidence, not a plan. Every item must be verifiable (pass/fail). Do not prescribe implementation approach. Include: scope (in/out), deliverables with locations, acceptance criteria covering all features (setup, dashboard, trending, new post, demo, LLM integration, persistence, visual design, testing), verification approach, quality/safety gates, non-goals.\n\nApply coverage checklist: build, tests, lint, docs, compatibility, security, ops, performance.\n\nWrite the proposed DoD to .ai/dod_c.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        consolidate_dod [
            auto_status=true,
            prompt="Synthesize the three DoD proposals into a single consensus Definition of Done.\n\nRead branch outputs via parallel_results.json + worktree_dir. If parallel_results.json is missing, fall back to reading .ai/dod_a.md, .ai/dod_b.md, .ai/dod_c.md in the current worktree. Read .ai/spec.md for context.\n\nResolve contradictions. Apply the DoD rubric (scope, deliverables, AC, verification, non-goals) and coverage checklist (build, tests, lint, docs, compatibility, security, ops, perf). Prefer the most specific and verifiable criteria from each branch.\n\nWrite the consensus DoD to .ai/definition_of_done.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=consolidate_dod_fail."
        ]
    }

    // =========================================================================
    // Planning Fanout
    // =========================================================================

    subgraph cluster_planning {
        label="Planning Fanout"
        node [shape=box]

        plan_fanout [shape=component, label="Plan Fan-Out"]

        plan_a [
            class="branch-a",
            prompt="Goal: $goal\n\nRead .ai/spec.md and .ai/definition_of_done.md. If .ai/postmortem_latest.md exists, incorporate its lessons.\n\nCreate an implementation plan for the Substack Creator Newsletter Engine covering all deliverables and acceptance criteria from the DoD. Be specific about:\n- React project setup (Vite + TypeScript + idb + @google/generative-ai SDK)\n- Module decomposition with file paths and estimated sizes (~200-500 lines each)\n- Core infrastructure: LLM client with structured JSON output and retry/backoff, IndexedDB persistence layer, shared UI components (rich input, card, progress bar, step indicators)\n- Feature modules: Setup flow, Dashboard, Trending Topics, New Post pipeline, Demo mode\n- Test infrastructure: integration (canned data), smoke (Flash Lite), manual (real models)\n- Deployment config: Railway config, validation scripts\n- Build/validate scripts: validate-build.sh, validate-fmt.sh, validate-test.sh, fix-fmt.sh, validate-artifacts.sh\n- Visual design: Substack-like serif styling, no spinners\n\nSpecify dependency ordering between modules.\n\nWrite to .ai/plan_a.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        plan_b [
            class="branch-b",
            prompt="Goal: $goal\n\nRead .ai/spec.md and .ai/definition_of_done.md. If .ai/postmortem_latest.md exists, incorporate its lessons.\n\nCreate an implementation plan for the Substack Creator Newsletter Engine covering all deliverables and acceptance criteria from the DoD. Be specific about:\n- React project setup (Vite + TypeScript + idb + @google/generative-ai SDK)\n- Module decomposition with file paths and estimated sizes (~200-500 lines each)\n- Core infrastructure: LLM client with structured JSON output and retry/backoff, IndexedDB persistence layer, shared UI components (rich input, card, progress bar, step indicators)\n- Feature modules: Setup flow, Dashboard, Trending Topics, New Post pipeline, Demo mode\n- Test infrastructure: integration (canned data), smoke (Flash Lite), manual (real models)\n- Deployment config: Railway config, validation scripts\n- Build/validate scripts: validate-build.sh, validate-fmt.sh, validate-test.sh, fix-fmt.sh, validate-artifacts.sh\n- Visual design: Substack-like serif styling, no spinners\n\nSpecify dependency ordering between modules.\n\nWrite to .ai/plan_b.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        plan_c [
            class="branch-c",
            prompt="Goal: $goal\n\nRead .ai/spec.md and .ai/definition_of_done.md. If .ai/postmortem_latest.md exists, incorporate its lessons.\n\nCreate an implementation plan for the Substack Creator Newsletter Engine covering all deliverables and acceptance criteria from the DoD. Be specific about:\n- React project setup (Vite + TypeScript + idb + @google/generative-ai SDK)\n- Module decomposition with file paths and estimated sizes (~200-500 lines each)\n- Core infrastructure: LLM client with structured JSON output and retry/backoff, IndexedDB persistence layer, shared UI components (rich input, card, progress bar, step indicators)\n- Feature modules: Setup flow, Dashboard, Trending Topics, New Post pipeline, Demo mode\n- Test infrastructure: integration (canned data), smoke (Flash Lite), manual (real models)\n- Deployment config: Railway config, validation scripts\n- Build/validate scripts: validate-build.sh, validate-fmt.sh, validate-test.sh, fix-fmt.sh, validate-artifacts.sh\n- Visual design: Substack-like serif styling, no spinners\n\nSpecify dependency ordering between modules.\n\nWrite to .ai/plan_c.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        debate_consolidate [
            auto_status=true,
            prompt="Synthesize the three implementation plans into a single best-of-breed final plan.\n\nRead branch outputs via parallel_results.json + worktree_dir. If parallel_results.json is missing, fall back to reading .ai/plan_a.md, .ai/plan_b.md, .ai/plan_c.md in the current worktree.\n\nIf .ai/postmortem_latest.md exists, verify the plan addresses every identified issue.\n\nRead .ai/spec.md and .ai/definition_of_done.md for context. Resolve conflicts between plans. Ensure dependency order is correct. Pick the most detailed and actionable approach for each module. The final plan must produce a work queue of bounded modules (~200-500 lines each), ordered so core infrastructure items come first (lower IDs), features next, and tests/deployment last.\n\nWrite the final plan to .ai/plan_final.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=debate_consolidate_fail."
        ]
    }

    // =========================================================================
    // Worker Pool
    // =========================================================================

    subgraph cluster_worker_pool {
        label="Worker Pool"

        plan_work [
            shape=box,
            auto_status=true,
            label="Plan Work Queue",
            prompt="Read .ai/plan_final.md, .ai/spec.md, and .ai/definition_of_done.md.\n\nCreate .ai/work_queue.json (skip if it already exists). The work queue lists bounded, independently-implementable modules for the Substack Creator Newsletter Engine. Each item has: id (int), module (string), description (string), and files (array of target file paths).\n\nOrder items so core infrastructure has lower IDs (0-3), feature modules have middle IDs (4-8), and test/deploy modules have higher IDs (9-10). Target ~200-500 lines per module. Typical decomposition:\n\nid 0: project_scaffold — package.json, vite.config.ts, tsconfig.json, index.html, src/main.tsx, src/App.tsx, scripts/validate-build.sh, scripts/validate-fmt.sh, scripts/validate-test.sh, scripts/fix-fmt.sh, scripts/validate-artifacts.sh\nid 1: llm_client — src/lib/llm.ts, src/lib/llm-schemas.ts (structured output, retry/backoff, model switching)\nid 2: persistence — src/lib/db.ts, src/lib/types.ts (IndexedDB via idb, all stores)\nid 3: shared_ui — src/components/RichInput.tsx, Card.tsx, ProgressBar.tsx, StepIndicator.tsx, src/styles/global.css\nid 4: setup_flow — src/pages/Settings.tsx and setup step components\nid 5: dashboard — src/pages/Dashboard.tsx, post/draft list components\nid 6: trending_topics — src/pages/TrendingTopics.tsx, trend visualization, writing prompts\nid 7: new_post — src/pages/NewPost.tsx, step components (Topic, Research, Outline, Write, Complete)\nid 8: demo_mode — src/lib/demo.ts, src/pages/DemoMode.tsx, src/demo/bundled-session.json\nid 9: test_infra — src/__tests__/ (integration with canned data, smoke with Flash Lite)\nid 10: deploy_config — railway.json or equivalent, deployment docs\n\nDerive the exact file list and descriptions from plan_final.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=work_queue_creation."
        ]

        work_pool [shape=component, label="Worker Pool"]

        worker_0 [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=300,
            max_tokens=32768,
            label="Worker 0",
            prompt="Goal: $goal\n\nRead .ai/work_queue.json, .ai/spec.md, .ai/definition_of_done.md, and .ai/plan_final.md.\n\nIf .ai/postmortem_latest.md exists, read it FIRST and fix ONLY identified gaps — do NOT regenerate working code. On repair passes, read and fix existing files rather than skipping them.\n\nImplement work items where item.id % 3 == 0. For each item on a fresh pass (no postmortem): check if target files already exist on disk and are non-empty — if so, skip that item. Implement each module with complete, functional code — no stubs, no placeholders, no TODO comments. Follow the plan and spec precisely.\n\nWorker 0 typically handles: project scaffold (id 0), shared UI components (id 3), trending topics (id 6), and test infrastructure (id 9).\n\nFor project scaffold (id 0): initialize React+TypeScript project with Vite. Install dependencies: react, react-dom, react-router-dom, idb, @google/generative-ai. Create directory structure. Write ALL validation scripts as committed deliverables:\n- scripts/validate-build.sh: runs npm run build, checks dist/ exists\n- scripts/validate-fmt.sh: runs npx prettier --check src/\n- scripts/validate-test.sh: runs npm test\n- scripts/fix-fmt.sh: runs npx prettier --write src/\n- scripts/validate-artifacts.sh: checks key deliverables exist and are non-empty\nAll scripts must start with #!/bin/sh, set -e, and include a POSIX sh failure trap.\n\nLog progress to .ai/implementation_log_w0.md.\n\nPRE-EXIT VERIFICATION: if .ai/postmortem_latest.md exists, run sh scripts/validate-build.sh and re-read each targeted file to confirm fixes are present before exiting.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=worker_0_impl."
        ]

        worker_1 [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=300,
            max_tokens=32768,
            label="Worker 1",
            prompt="Goal: $goal\n\nRead .ai/work_queue.json, .ai/spec.md, .ai/definition_of_done.md, and .ai/plan_final.md.\n\nIf .ai/postmortem_latest.md exists, read it FIRST and fix ONLY identified gaps — do NOT regenerate working code. On repair passes, read and fix existing files rather than skipping them.\n\nImplement work items where item.id % 3 == 1. For each item on a fresh pass (no postmortem): check if target files already exist on disk and are non-empty — if so, skip that item. Implement each module with complete, functional code — no stubs, no placeholders, no TODO comments.\n\nWorker 1 typically handles: LLM client (id 1), setup flow (id 4), new post pipeline (id 7), and deploy config (id 10).\n\nFor LLM client (id 1): implement structured JSON output mode with schema enforcement, retry with error feedback and intelligent backoff, model switching between Flash/Pro/Lite, client-side API key usage. All calls must enforce structured output and retry on malformed responses.\n\nFor new post pipeline (id 7): implement the full 5-step flow — Topic (rich input + Research button), Research (Flash search grounding, source cards with URL/title/author/date metadata, highlight/delete), Outline (Pro one-shot, accept/back), Write cycles (3 automatic Pro cycles: Write with citations, Edit for style, Guardrails-only pass), Complete (serif formatted post with numbered footnotes, linked sources, attribution lineage preserved end-to-end).\n\nLog progress to .ai/implementation_log_w1.md.\n\nPRE-EXIT VERIFICATION: if .ai/postmortem_latest.md exists, run sh scripts/validate-build.sh and re-read each targeted file to confirm fixes are present before exiting.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=worker_1_impl."
        ]

        worker_2 [
            shape=box,
            class="hard",
            auto_status=true,
            max_agent_turns=300,
            max_tokens=32768,
            label="Worker 2",
            prompt="Goal: $goal\n\nRead .ai/work_queue.json, .ai/spec.md, .ai/definition_of_done.md, and .ai/plan_final.md.\n\nIf .ai/postmortem_latest.md exists, read it FIRST and fix ONLY identified gaps — do NOT regenerate working code. On repair passes, read and fix existing files rather than skipping them.\n\nImplement work items where item.id % 3 == 2. For each item on a fresh pass (no postmortem): check if target files already exist on disk and are non-empty — if so, skip that item. Implement each module with complete, functional code — no stubs, no placeholders, no TODO comments.\n\nWorker 2 typically handles: persistence layer (id 2), dashboard (id 5), and demo mode (id 8).\n\nFor persistence (id 2): implement IndexedDB via idb library with stores for: configuration (API key, company, voice, guardrails), drafts (in-progress post state), sessions (all inputs, LLM responses, intermediate state for recording/replay), post history (completed posts with Markdown and attribution mappings). All data persists indefinitely unless user resets.\n\nFor demo mode (id 8): implement session recording (capture all inputs/responses during production flow), replay through production code path (prefill text with fade-in, attachments appear after delay, highlight next button), bundled P&G session in src/demo/, cache-miss error display with no API fallback, session picker UI.\n\nLog progress to .ai/implementation_log_w2.md.\n\nPRE-EXIT VERIFICATION: if .ai/postmortem_latest.md exists, run sh scripts/validate-build.sh and re-read each targeted file to confirm fixes are present before exiting.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=worker_2_impl."
        ]

        check_work_complete [
            shape=box,
            auto_status=true,
            label="Work Complete?",
            prompt="Read .ai/work_queue.json and check whether all items have their target files present on disk (non-empty).\n\nRead .ai/work_pass.txt — if missing, create it with value 1. If it exists, read the current pass number, increment it, and write back.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):\n- If all items have their target files on disk: status=all_done\n- If some items are still missing: status=more_work\n- If pass count exceeds 5: status=fail with failure_reason=Worker pool stalled after 5 passes, failure_class=deterministic_agent_bug, failure_signature=worker_pool_stall"
        ]

        merge_implementation [
            shape=box,
            auto_status=true,
            max_agent_turns=200,
            prompt="Read .ai/work_queue.json and worker implementation logs (.ai/implementation_log_w0.md, .ai/implementation_log_w1.md, .ai/implementation_log_w2.md).\n\nRead branch outputs via parallel_results.json + worktree_dir. If parallel_results.json is missing, fall back to reading files in the current worktree.\n\nVerify all modules have been implemented by checking that target files from each work item exist on disk. Then resolve integration issues:\n1. Ensure App.tsx routing includes all pages (Settings, Dashboard, TrendingTopics, NewPost, DemoMode)\n2. Verify imports and exports are consistent across modules\n3. Verify shared components (RichInput, Card, ProgressBar, StepIndicator) are used consistently\n4. Verify LLM client is imported correctly by all feature modules\n5. Verify IndexedDB stores are accessed consistently\n6. Run npm install to ensure dependencies are complete\n7. Fix any TypeScript compilation errors\n\nWrite .ai/merge_report.md summarizing integration status and any fixes applied.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH) ONLY on failure: status=fail with failure_reason, failure_class, and failure_signature=merge_impl."
        ]
    }

    // =========================================================================
    // Verify Chain
    // =========================================================================

    subgraph cluster_verify {
        label="Verify"

        check_merge [shape=diamond, label="Merge OK?"]

        fix_fmt [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh scripts/fix-fmt.sh || { echo 'KILROY_VALIDATE_FAILURE: fix-fmt.sh missing or failed — postmortem must write scripts/fix-fmt.sh'; exit 1; }"
        ]

        verify_fmt [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh scripts/validate-fmt.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-fmt.sh missing or failed — postmortem must write scripts/validate-fmt.sh'; exit 1; }"
        ]
        check_fmt [shape=diamond, label="Fmt OK?"]

        verify_build [
            shape=parallelogram,
            tool_command="sh scripts/validate-build.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-build.sh missing or failed — postmortem must write scripts/validate-build.sh'; exit 1; }"
        ]
        check_build [shape=diamond, label="Build OK?"]

        verify_test [
            shape=parallelogram,
            tool_command="sh scripts/validate-test.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-test.sh missing or failed — postmortem must write scripts/validate-test.sh'; exit 1; }"
        ]
        check_test [shape=diamond, label="Tests OK?"]

        verify_artifacts [
            shape=parallelogram,
            max_retries=0,
            tool_command="sh scripts/validate-artifacts.sh || { echo 'KILROY_VALIDATE_FAILURE: validate-artifacts.sh missing or failed — postmortem must write scripts/validate-artifacts.sh'; exit 1; }"
        ]
        check_artifacts [shape=diamond, label="Artifacts OK?"]

        verify_fidelity [
            shape=box,
            class="verify",
            prompt="Read the implementation and verify against .ai/definition_of_done.md and .ai/spec.md. Enumerate acceptance criteria by ID and map each to specific output files:\n\nAC-1 (Build and Deploy): package.json, vite.config.ts, dist/, railway.json — verify npm build exits 0, deployment config references build output, no live deployment\nAC-2 (Persistence): src/lib/db.ts — verify IndexedDB stores API key, config, posts, drafts, sessions with citation-to-source attribution mappings\nAC-3 (LLM Integration): src/lib/llm.ts — verify structured JSON output mode, retry with error feedback and backoff, model switching (Flash/Pro/Lite), client-side API key\nAC-4 (Setup Flow): src/pages/Settings.tsx — verify parallel setup (any order), status icons, rich input, Pro confirmation with back button, reset everything\nAC-5 (Dashboard): src/pages/Dashboard.tsx — verify New Post button, Trending Topics button, Settings access, past posts list, draft resume\nAC-6 (Trending Topics): src/pages/TrendingTopics.tsx — verify Flash search-grounded research, deterministic trend visualization, 3 Pro writing prompts, navigation to New Post\nAC-7 (New Post): src/pages/NewPost.tsx — verify 5-step pipeline, source metadata (URL/title/author/date), highlight/delete sources, automatic write cycles, citations with attribution lineage end-to-end\nAC-8 (Demo Mode): src/pages/DemoMode.tsx — verify session picker, production code path replay, fade-in prefill, highlighted next button, cache-miss error (no API fallback), bundled P&G session\nAC-9 (Visual Design): src/styles/ — verify Substack styling (serif fonts, accent progress bars, card primitives, step dot indicators, no spinners), final post looks like real Substack\nAC-10 (Testing): src/__tests__/ — verify integration tests with canned data pass offline, smoke tests with Flash Lite, manual test option\n\nWrite results to .ai/verify_fidelity.md with PASS/FAIL per AC and specific evidence.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):\nAll pass: status=success.\nAny fail: status=fail with failure_reason listing failing ACs, failure_class=deterministic_agent_bug, failure_signature as sorted comma-separated failing AC IDs (e.g. AC-2,AC-7,AC-9)."
        ]
        check_impl [shape=diamond, label="Impl OK?"]
    }

    // =========================================================================
    // Review Fanout
    // =========================================================================

    subgraph cluster_review {
        label="Review Fanout"
        node [shape=box]

        review_fanout [shape=component, label="Review Fan-Out"]

        review_a [
            class="branch-a",
            prompt="Review the Substack Creator Newsletter Engine implementation against .ai/definition_of_done.md.\n\nRead the DoD for acceptance criteria. Read all implementation source files. Check every AC group (AC-1 through AC-10):\n\nAC-1: Build exits 0, static assets produced, deployment config present and coherent (review only, no live deploy)\nAC-2: IndexedDB persistence for API key, config, posts, drafts, sessions, attribution mappings across reloads\nAC-3: Structured JSON output with retry/backoff, correct model routing (Flash/Pro/Lite), client-side key\nAC-4: Parallel setup (any order), status icons, rich input (text/upload/link), Pro confirmation, back button\nAC-5: Dashboard with New Post and Trending Topics buttons, Settings link, post history, draft resume\nAC-6: Trending Topics: parallel Flash search research, trend visualization, 3 Pro writing prompts, navigate to New Post\nAC-7: Full post pipeline with source metadata, highlight/delete, one-shot outline, 3 automatic write cycles, citations with attribution lineage\nAC-8: Demo replay through production path, fade-in/highlight, bundled P&G session, cache-miss error\nAC-9: Substack visual design: serif fonts, step dots, card primitive, accent progress bars, no spinners, footnoted post\nAC-10: Integration tests (canned), smoke tests (Flash Lite), manual option\n\nVerdict: APPROVED (all criteria met with evidence) or REJECTED (specific gaps by AC ID).\nWrite to .ai/review_a.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        review_b [
            class="branch-b",
            prompt="Review the Substack Creator Newsletter Engine implementation against .ai/definition_of_done.md.\n\nRead the DoD for acceptance criteria. Read all implementation source files. Check every AC group (AC-1 through AC-10):\n\nAC-1: Build exits 0, static assets produced, deployment config present and coherent (review only, no live deploy)\nAC-2: IndexedDB persistence for API key, config, posts, drafts, sessions, attribution mappings across reloads\nAC-3: Structured JSON output with retry/backoff, correct model routing (Flash/Pro/Lite), client-side key\nAC-4: Parallel setup (any order), status icons, rich input (text/upload/link), Pro confirmation, back button\nAC-5: Dashboard with New Post and Trending Topics buttons, Settings link, post history, draft resume\nAC-6: Trending Topics: parallel Flash search research, trend visualization, 3 Pro writing prompts, navigate to New Post\nAC-7: Full post pipeline with source metadata, highlight/delete, one-shot outline, 3 automatic write cycles, citations with attribution lineage\nAC-8: Demo replay through production path, fade-in/highlight, bundled P&G session, cache-miss error\nAC-9: Substack visual design: serif fonts, step dots, card primitive, accent progress bars, no spinners, footnoted post\nAC-10: Integration tests (canned), smoke tests (Flash Lite), manual option\n\nVerdict: APPROVED (all criteria met with evidence) or REJECTED (specific gaps by AC ID).\nWrite to .ai/review_b.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        review_c [
            class="branch-c",
            prompt="Review the Substack Creator Newsletter Engine implementation against .ai/definition_of_done.md.\n\nRead the DoD for acceptance criteria. Read all implementation source files. Check every AC group (AC-1 through AC-10):\n\nAC-1: Build exits 0, static assets produced, deployment config present and coherent (review only, no live deploy)\nAC-2: IndexedDB persistence for API key, config, posts, drafts, sessions, attribution mappings across reloads\nAC-3: Structured JSON output with retry/backoff, correct model routing (Flash/Pro/Lite), client-side key\nAC-4: Parallel setup (any order), status icons, rich input (text/upload/link), Pro confirmation, back button\nAC-5: Dashboard with New Post and Trending Topics buttons, Settings link, post history, draft resume\nAC-6: Trending Topics: parallel Flash search research, trend visualization, 3 Pro writing prompts, navigate to New Post\nAC-7: Full post pipeline with source metadata, highlight/delete, one-shot outline, 3 automatic write cycles, citations with attribution lineage\nAC-8: Demo replay through production path, fade-in/highlight, bundled P&G session, cache-miss error\nAC-9: Substack visual design: serif fonts, step dots, card primitive, accent progress bars, no spinners, footnoted post\nAC-10: Integration tests (canned), smoke tests (Flash Lite), manual option\n\nVerdict: APPROVED (all criteria met with evidence) or REJECTED (specific gaps by AC ID).\nWrite to .ai/review_c.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH): On success: status=success. On failure: status=fail with failure_reason and failure_class."
        ]

        review_consensus [
            auto_status=true,
            goal_gate=true,
            retry_target="postmortem",
            prompt="Synthesize the three reviews into a consensus verdict.\n\nRead branch outputs via parallel_results.json + worktree_dir. If parallel_results.json is missing, fall back to reading .ai/review_a.md, .ai/review_b.md, .ai/review_c.md in the current worktree.\n\nRead .ai/definition_of_done.md for acceptance criteria reference.\n\nConsensus rules:\n- 2+ APPROVED with no critical gaps across any review: the implementation passes\n- Any critical gap identified by 2+ reviewers: rejected with specific AC IDs\n- Mixed verdicts with critical gaps: rejected with gaps enumerated\n\nIMPORTANT: Do NOT write status=fail for a rejection — use status=rejected instead.\n\nWrite to .ai/review_consensus.md.\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH):\nApproved: status=success.\nRejected: status=rejected with failure_reason listing failing ACs."
        ]
    }

    // =========================================================================
    // Postmortem
    // =========================================================================

    subgraph cluster_postmortem {
        label="Postmortem"

        postmortem [
            shape=box,
            auto_status=true,
            prompt="Analyze the failure and guide the next repair iteration.\n\nRead (if they exist):\n- .ai/review_consensus.md\n- .ai/verify_fidelity.md\n- .ai/merge_report.md\n- .ai/implementation_log_w0.md, .ai/implementation_log_w1.md, .ai/implementation_log_w2.md\n- Branch review outputs via parallel_results.json + worktree_dir (if available)\n\nOutput to .ai/postmortem_latest.md (overwrite previous):\n- Root causes of failure\n- What works and must be preserved\n- What failed and must be fixed\n- Concrete next changes (specific files, specific fixes)\n- Do NOT direct from-scratch restart — preserve working code\n\nPROGRESS DETECTION (required):\nExtract current failing AC IDs from verify_fidelity.md or review outputs. Read context key last_failing_acs (from previous postmortem iteration). Compare:\n- If failing AC set is IDENTICAL to last_failing_acs: route needs_replan (zero progress — another impl_repair will not help)\n- If failing AC set is smaller or different, or this is the first failure: route impl_repair\n\nOUTCOME CLASSIFICATION:\n- impl_repair: code repair needed, plan and toolchain are valid\n- needs_replan: plan/approach is inadequate, OR zero progress detected\n- needs_toolchain: environment/bootstrap/toolchain issue detected\n- When uncertain on first failure, default to impl_repair\n\nWrite to $KILROY_STAGE_STATUS_PATH (fallback: $KILROY_STAGE_STATUS_FALLBACK_PATH).\nAlways write one of: status=impl_repair, status=needs_replan, or status=needs_toolchain.\nAlways include context_updates with last_failing_acs (sorted, comma-separated failing AC IDs).\nOn analysis failure: status=fail with failure_reason, failure_class, failure_signature=postmortem_analysis."
        ]
    }

    // =========================================================================
    // Edges
    // =========================================================================

    // Bootstrap
    start -> check_toolchain
    check_toolchain -> expand_spec [condition="outcome=success"]
    check_toolchain -> check_toolchain [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_toolchain -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_toolchain -> postmortem
    expand_spec -> check_dod

    // DoD routing
    check_dod -> plan_fanout [condition="outcome=has_dod"]
    check_dod -> dod_fanout [condition="outcome=needs_dod"]
    check_dod -> dod_fanout
    dod_fanout -> dod_a
    dod_fanout -> dod_b
    dod_fanout -> dod_c
    dod_a -> consolidate_dod
    dod_b -> consolidate_dod
    dod_c -> consolidate_dod
    consolidate_dod -> plan_fanout

    // Planning
    plan_fanout -> plan_a
    plan_fanout -> plan_b
    plan_fanout -> plan_c
    plan_a -> debate_consolidate
    plan_b -> debate_consolidate
    plan_c -> debate_consolidate
    debate_consolidate -> plan_work

    // Worker pool
    plan_work -> work_pool
    work_pool -> worker_0
    work_pool -> worker_1
    work_pool -> worker_2
    worker_0 -> check_work_complete
    worker_1 -> check_work_complete
    worker_2 -> check_work_complete
    check_work_complete -> work_pool [condition="outcome=more_work", loop_restart=true]
    check_work_complete -> merge_implementation [condition="outcome=all_done"]
    check_work_complete -> postmortem [condition="outcome=fail"]
    check_work_complete -> merge_implementation

    // Verify chain
    merge_implementation -> check_merge
    check_merge -> fix_fmt [condition="outcome=success"]
    check_merge -> plan_work [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_merge -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_merge -> postmortem

    fix_fmt -> verify_fmt
    verify_fmt -> check_fmt
    check_fmt -> verify_build [condition="outcome=success"]
    check_fmt -> plan_work [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_fmt -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_fmt -> postmortem

    verify_build -> check_build
    check_build -> verify_test [condition="outcome=success"]
    check_build -> plan_work [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_build -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_build -> postmortem

    verify_test -> check_test
    check_test -> verify_artifacts [condition="outcome=success"]
    check_test -> plan_work [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_test -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_test -> postmortem

    verify_artifacts -> check_artifacts
    check_artifacts -> verify_fidelity [condition="outcome=success"]
    check_artifacts -> plan_work [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_artifacts -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_artifacts -> postmortem

    verify_fidelity -> check_impl
    check_impl -> review_fanout [condition="outcome=success"]
    check_impl -> plan_work [condition="outcome=fail && context.failure_class=transient_infra", loop_restart=true]
    check_impl -> postmortem [condition="outcome=fail && context.failure_class!=transient_infra"]
    check_impl -> postmortem

    // Review
    review_fanout -> review_a
    review_fanout -> review_b
    review_fanout -> review_c
    review_a -> review_consensus
    review_b -> review_consensus
    review_c -> review_consensus
    review_consensus -> exit [condition="outcome=success"]
    review_consensus -> postmortem

    // Postmortem recovery routing
    postmortem -> check_toolchain [condition="outcome=fail && context.failure_class=transient_infra"]
    postmortem -> plan_work [condition="outcome=impl_repair"]
    postmortem -> plan_fanout [condition="outcome=needs_replan"]
    postmortem -> check_toolchain [condition="outcome=needs_toolchain"]
    postmortem -> plan_work
}
